# systemd EnvironmentFile — CSERVICE_* only（企微 kf 凭证在此仓，不在 skstudio）
HERMES_SHARED_ROOT=/var/lib/hermes

CSERVICE_DB_PATH=/var/lib/cs/cservice/data/cservice.db
CSERVICE_DATA_ROOT=/var/lib/cs/cservice

# 须与 skstudio JWT_SECRET 同值
CSERVICE_JWT_SECRET=替换为与-skstudio-JWT_SECRET-同值
CSERVICE_JWT_ALGORITHM=HS256

# skstudio BFF Bearer（须与 skstudio CSERVICE_SERVICE_TOKEN 同值）
CSERVICE_SERVICE_TOKEN=替换为强随机-token-与-skstudio-同值

# 企微 kf（真实入站/出站前须配置；UI 演示可留空）
CSERVICE_WECOM_CORP_ID=
CSERVICE_WECOM_SECRET=
CSERVICE_KF_CALLBACK_TOKEN=
CSERVICE_KF_CALLBACK_AES_KEY=

HOST=127.0.0.1
PORT=8093
