# cservice 进程环境变量（CSERVICE_* · 企微 kf 凭证在此仓，不在 skstudio）
# 本地默认 ~/.hermes/cservice/data/cservice.db（dev-cservice.sh 自动写入）
CSERVICE_DB_PATH=~/.hermes/cservice/data/cservice.db
CSERVICE_DATA_ROOT=~/.hermes/cservice

# 须与 skstudio JWT_SECRET 同值（BFF 转发员工 JWT）
CSERVICE_JWT_SECRET=change-me
CSERVICE_JWT_ALGORITHM=HS256

# skstudio BFF 调本服务 REST（须与 skstudio CSERVICE_SERVICE_TOKEN 同值）
CSERVICE_SERVICE_TOKEN=dev-cservice-service-token

# 企微 kf（M2+；M1 health 仅检查是否配置）
CSERVICE_WECOM_CORP_ID=
CSERVICE_WECOM_SECRET=
CSERVICE_KF_CALLBACK_TOKEN=
CSERVICE_KF_CALLBACK_AES_KEY=

# UI 演示：未配置企微 kf 时模拟 send_msg 成功（勿在生产接真客时开启）
CSERVICE_DEMO_OUTBOUND=0

# 企微客户群（P4 · 路径 A 生产试点）
CSERVICE_WG_ENABLED=0
CSERVICE_WG_AUTO_REGISTER=1
CSERVICE_WG_BROADCAST_ENABLED=0

HOST=127.0.0.1
PORT=8093
